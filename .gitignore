# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
.next/
out/
dist/
.wrangler/

# Data — vintages are tracked via manifests, not committed raw parquet (too large).
# The manifest + fetcher seed + vintage_utc is sufficient for reproducibility.
data/vintages/**/*.parquet
data/vintages/**/*.csv
data/raw/

# Generated coverage artifact — source of truth is hypotheses/ + publishers.yaml
data/manifests/coverage.derived.yaml

# Private archive (Telegram corpus mining) — never committed
archive/
hypotheses/candidates/

# Legacy hand-curated coverage (being migrated into publishers.yaml)
data/manifests/coverage.yaml

# Run artifacts — large model outputs. Coefficients are the result and
# should be committed; samples/bootstraps/fitted objects can be large.
engine/runs/**/samples.parquet
engine/runs/**/bootstrap.parquet
engine/runs/**/fitted_model.parquet
engine/runs/**/*.pkl
engine/runs/**/*.joblib

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Secrets
.env
.env.local
*.pem
*.key

# LLM prompt caches
.anthropic/
.cache/

# Build caches
*.tsbuildinfo
web/.next/

# Claude session state
.claude/worktrees/

# Manual data drops — large source files (PWT xlsx, etc), regenerated from
# upstream URL; not committed because they bloat the repo.
data/manual/**/*.xlsx
data/manual/**/*.xls
data/manual/**/*.dta
data/manual/**/*.csv
/data/vintages
/.venv
/web/node_modules
