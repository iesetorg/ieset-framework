{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ieset.dev/schemas/second_order_data_source_inventory.schema.json",
  "title": "IESET Second-order Data Source Inventory",
  "description": "Research and ingestion inventory for dataset families that can unlock second-order policy gates.",
  "type": "object",
  "required": [
    "version",
    "last_seeded_utc",
    "program",
    "backlog_snapshot",
    "source_records"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "last_seeded_utc": {"type": "string", "minLength": 10},
    "program": {"type": "string", "minLength": 10},
    "backlog_snapshot": {
      "type": "object",
      "required": [
        "strict_held_public_claim_links",
        "strict_eligible_public_claim_links",
        "held_hypotheses",
        "policies_missing_explicit_design",
        "policies_needing_treated_comparison_units",
        "policies_needing_exact_event_dates"
      ],
      "additionalProperties": false,
      "properties": {
        "strict_held_public_claim_links": {"type": "integer", "minimum": 0},
        "strict_eligible_public_claim_links": {"type": "integer", "minimum": 0},
        "held_hypotheses": {"type": "integer", "minimum": 0},
        "policies_missing_explicit_design": {"type": "integer", "minimum": 0},
        "policies_needing_treated_comparison_units": {"type": "integer", "minimum": 0},
        "policies_needing_exact_event_dates": {"type": "integer", "minimum": 0}
      }
    },
    "source_records": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source_record"}
    }
  },
  "$defs": {
    "second_order_layer": {
      "type": "string",
      "enum": [
        "first_order_price_or_transfer",
        "first_order_policy_effect",
        "second_order_supply_response",
        "behavioral_response",
        "allocation_distortion",
        "leakage_or_substitution",
        "quality_margin",
        "fiscal_or_enforcement_cost",
        "implementation_capacity",
        "market_structure_response",
        "dynamic_investment_response",
        "macro_feedback",
        "externality_or_spillover",
        "net_welfare",
        "distributional_incidence"
      ]
    },
    "source_record": {
      "type": "object",
      "required": [
        "source_id",
        "source_name",
        "source_family_id",
        "publisher",
        "domain",
        "geography",
        "unit_of_observation",
        "time_coverage",
        "policy_or_outcome_fields",
        "access_format",
        "source_url",
        "license_or_terms",
        "update_frequency",
        "second_order_layers",
        "gate_unlocks",
        "acquisition_status",
        "ingestion_difficulty",
        "immediate_payoff_rank",
        "verification_status",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "source_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"},
        "source_name": {"type": "string", "minLength": 3},
        "source_family_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"},
        "publisher": {"type": "string", "minLength": 2},
        "domain": {"type": "string", "minLength": 3},
        "geography": {"type": "string", "minLength": 2},
        "unit_of_observation": {"type": "string", "minLength": 3},
        "time_coverage": {"type": "string", "minLength": 2},
        "policy_or_outcome_fields": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 2}
        },
        "access_format": {"type": "string", "minLength": 2},
        "source_url": {"type": "string", "minLength": 8},
        "license_or_terms": {"type": "string", "minLength": 2},
        "update_frequency": {"type": "string", "minLength": 2},
        "second_order_layers": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/second_order_layer"}
        },
        "gate_unlocks": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 8}
        },
        "acquisition_status": {
          "type": "string",
          "enum": [
            "ready",
            "partial_ready",
            "manual_drop",
            "scrape_needed",
            "reconstruct_needed",
            "proprietary_gap",
            "restricted_access",
            "no_known_source"
          ]
        },
        "ingestion_difficulty": {"type": "string", "enum": ["low", "medium", "high"]},
        "immediate_payoff_rank": {"type": "integer", "minimum": 1},
        "verification_status": {
          "type": "string",
          "enum": [
            "scout_reported_unverified",
            "seed_unverified_url",
            "seed_verified_official_page",
            "endpoint_verified",
            "codebook_verified",
            "license_verified",
            "production_ready"
          ]
        },
        "notes": {"type": "string", "minLength": 10}
      }
    }
  }
}
