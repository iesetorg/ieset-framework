{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ieset.dev/schemas/axes.schema.json",
  "title": "IESET Policy Axes Taxonomy",
  "description": "Canonical list of policy axes. Policies are scored per-axis; movements summarise across axes. Every `axis` string in a policy/movement YAML must reference an id defined here. Axes are grouped by channel per Invariant 4 (fiscal vs regulatory separation).",
  "type": "object",
  "required": ["version", "axes"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "axes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "channel", "description", "direction_semantics"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(fiscal|regulatory|monetary|institutional)\\.[a-z][a-z0-9_]*[a-z0-9]$",
            "description": "Dotted id: <channel>.<axis_name>"
          },
          "channel": {
            "type": "string",
            "enum": ["fiscal", "regulatory", "monetary", "institutional"]
          },
          "description": {"type": "string", "minLength": 30},
          "direction_semantics": {
            "type": "object",
            "required": ["+", "-"],
            "additionalProperties": false,
            "properties": {
              "+": {"type": "string", "description": "What moving in the + direction means (policy-content, not normative)."},
              "-": {"type": "string", "description": "What moving in the - direction means."}
            }
          },
          "source_publishers": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Publisher ids (per publishers.yaml) that carry axis-level panel data. Informs which fetchers the data agent needs ready for axis-level charts."
          },
          "typical_proxies": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Series or indices commonly used to measure this axis, e.g. 'Fraser EFW area 1b' or 'OECD PMR aggregate'."
          },
          "second_order_measurement": {
            "type": "object",
            "description": "Optional axis-level measurement guidance for interventions where first-order outcomes can hide supply, allocation, quality, leakage, fiscal, welfare, or distributional effects.",
            "additionalProperties": false,
            "properties": {
              "required_layers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "first_order_price_or_transfer",
                    "first_order_policy_effect",
                    "second_order_supply_response",
                    "behavioral_response",
                    "allocation_distortion",
                    "leakage_or_substitution",
                    "quality_margin",
                    "fiscal_or_enforcement_cost",
                    "implementation_capacity",
                    "market_structure_response",
                    "dynamic_investment_response",
                    "macro_feedback",
                    "externality_or_spillover",
                    "net_welfare",
                    "distributional_incidence"
                  ]
                }
              },
              "preferred_designs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "controlled_vs_uncontrolled_units",
                    "controlled_vs_uncontrolled_categories",
                    "treated_vs_untreated_units",
                    "eligible_vs_ineligible_groups",
                    "phase_in_or_threshold_comparison",
                    "adjacent_market_comparison",
                    "border_comparison",
                    "high_frequency_event_study",
                    "triple_difference",
                    "welfare_accounting",
                    "distributional_decomposition",
                    "quality_margin",
                    "leakage_substitution",
                    "implementation_capacity_check",
                    "mechanism_channel_decomposition",
                    "dynamic_investment_followup",
                    "spillover_tracking"
                  ]
                }
              },
              "canonical_outcomes": {"type": "array", "items": {"type": "string"}},
              "notes": {"type": "string"}
            }
          },
          "notes": {"type": "string"}
        }
      }
    }
  }
}
