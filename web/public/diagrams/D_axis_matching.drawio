<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="Axis matching" id="axis-matching">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" page="1" pageWidth="1200" pageHeight="900">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="input" value="STEP 1 — INPUT&#10;Proposed policy: UK financial-sector liberalisation&#10;&#10;regulatory.financial_deregulation  ↑  strong&#10;fiscal.tax_capital                 ↓  moderate&#10;institutional.property_rights      ↑  weak" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;fontFamily=monospace;fontSize=12;align=left;verticalAlign=top;spacingLeft=16;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="480" height="200" as="geometry" />
        </mxCell>

        <mxCell id="matcher" value="STEP 2 — MATCHER&#10;&#10;score = Σ (same_dir ? 1 : 0.5)&#10;     × magnitude_weight&#10;&#10;over every shared axis with&#10;every policy in the corpus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1ecf5;strokeColor=#1f4e79;strokeWidth=2;fontColor=#1f4e79;fontStyle=1;align=left;verticalAlign=top;spacingLeft=16;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="360" height="200" as="geometry" />
        </mxCell>

        <mxCell id="corpus" value="1,130 POLICIES" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafaf8;strokeColor=#ececec;fontSize=11;fontStyle=1;fontColor=#636363;" vertex="1" parent="1">
          <mxGeometry x="1000" y="60" width="160" height="200" as="geometry" />
        </mxCell>

        <mxCell style="endArrow=classic;html=1;strokeColor=#1f4e79;" edge="1" parent="1" source="input" target="matcher"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1;strokeColor=#1f4e79;" edge="1" parent="1" source="corpus" target="matcher"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="out_h" value="STEP 3 — OUTPUT&#10;Ranked historical analogues. Shared axes in blue = same direction (strong signal)." style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="1120" height="40" as="geometry" />
        </mxCell>

        <mxCell id="match1" value="1. UK Big Bang (1986) — 4.2&#10;shared: regulatory.financial_deregulation, fiscal.tax_capital" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=middle;spacingLeft=16;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="1120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="match2" value="2. US Gramm-Leach-Bliley (1999) — 3.8&#10;shared: regulatory.financial_deregulation   opposite: institutional.property_rights" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=middle;spacingLeft=16;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="1120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="match3" value="3. Iceland financial liberalisation (2001-2007) — 3.3&#10;shared: regulatory.financial_deregulation, institutional.property_rights" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=middle;spacingLeft=16;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="1120" height="70" as="geometry" />
        </mxCell>

        <mxCell style="endArrow=classic;html=1;strokeColor=#1f4e79;" edge="1" parent="1" source="matcher" target="out_h"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
